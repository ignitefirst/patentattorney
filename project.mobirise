        {
          "_name": "header2",
          "_sourceTheme": "kidsm4",
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 15px)",
              "padding-bottom": "(@paddingBottom * 15px)",
              "@media (max-width: 767px)": {
                "padding-top": "(@paddingTop * 5px)",
                "padding-bottom": "(@paddingBottom * 5px)"
              }
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "img": {
              "width": "100%",
              "border-radius": "30px",
              "transform": "translate(1%, 5%)"
            },
            ".right-wrapper": {
              "padding-left": "5rem"
            },
            ".btn": {
              "padding": "0.7rem 2.4rem",
              "position": "relative"
            },
            ".container-fluid": {
              "max-width": "1200px",
              "padding": "0 1.4rem"
            },
            ".mbr-text": {
              "margin-top": "1.5rem",
              "margin-bottom": "2.5rem"
            },
            ".imageContainer": {
              "display": "inline-block",
              "position": "relative",
              "z-index": "0",
              "&:before": {
                "content": "''",
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "96%",
                "height": "100%",
                "border": "2px dashed @warningColor",
                "border-radius": "30px",
                "z-index": "-1"
              }
            },
            ".btn:hover .inner-dashed-border": {
              "animation-play-state": "running"
            },
            "@keyframes dashed_border_running": {
              "100%": {
                "stroke-dashoffset": "-1000"
              }
            },
            ".svg1": {
              "position": "absolute",
              "padding": "2px",
              "rect": {
                "width": "~\"calc(100% - 4px)\"",
                "height": "~\"calc(100% - 4px)\""
              }
            },
            "@media (min-width: 767px) and (max-width: 992px)": {
              ".imageContainer": {
                "margin-bottom": "4.2rem"
              },
              ".right-wrapper": {
                "padding-left": "1.2rem"
              }
            },
            "@media (max-width: 767px)": {
