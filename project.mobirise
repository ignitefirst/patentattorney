                "background-image": "url(@fallBackImage)"
              }
            }
          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content10 marketm4_content10\" group=\"Content\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\n\t<mbr-parameters>\n\t\t\n\t\t<header>Size</header>\n\t\t<input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"1\">\n\t\t<input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"6\">\n\t\t<input type=\"range\" inline title=\"Content Width\" name=\"contentWidth\" min=\"1\" max=\"5\" step=\"1\" value=\"5\">\n\t\t<select name=\"alignContent\" title=\"Align Content\">\n\t\t\t<option value=\"1\">Left</option>\n\t\t\t<option value=\"2\" selected>Center</option>\n\t\t\t<option value=\"3\">Right</option>\n\t\t</select>\n\t\t<header>Show/Hide</header>\n\t\t<input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n\t\t<input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n\t\t<input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n\t\t<input type=\"checkbox\" title=\"Icon\" name=\"showIcon\">\n\t\t<input type=\"color\" title=\"Icon Color\" value=\"#ebeaed\" name=\"iconColor\" condition=\"showIcon\">\n\t\t<input type=\"color\" title=\"Border Color\" value=\"#000000\" name=\"borderColor\">\n\t\t<header>Background</header>\n\t\t<fieldset type=\"background\" name=\"bg\" parallax>\n\t\t\t<input type=\"image\" title=\"Image\" value=\"@PROJECT_PATH@/assets/images/bg1.jpg\" parallax>\n\t\t\t<input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n\t\t\t<input type=\"video\" title=\"Video\" value=\"https://www.youtube.com/watch?v=36YgDDJ7XSc\">\n\t\t</fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@PROJECT_PATH@/assets/images/background1-3.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n\t\t<input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n\t\t<input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#2f1893\" condition=\"overlay && bg.type !== 'color'\">\n\t\t<input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.9\" condition=\"overlay && bg.type !== 'color'\">\n\t\t\n\t</mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\n\n\t<div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n\n\t<div class=\"container\">\n\t\t<div class=\"row text-center\" mbr-class=\"{'justify-content-center' : alignContent == 2, 'justify-content-end' : alignContent == 3}\">\n\t\t\t<div class mbr-class=\"{'col-lg-6 col-md-8': contentWidth == 1, 'col-lg-7 col-md-9': contentWidth == 2, 'col-lg-8 col-md-10': contentWidth == 3,'col-lg-9': contentWidth == 4, 'col-lg-10': contentWidth == 5}\">\n\t\t\t\t<div class=\"block__inner\">\n\t\t\t\t\t<div class=\"row justify-content-center\">\n\t\t\t\t\t\t<div class=\"col-lg-8 col-md-10\">\n\t\t\t\t\t\t\t<span mbr-icon class=\"mbr-iconfont mbrib-mobirise\" mbr-if=\"showIcon\"></span>\n\t\t\t\t\t\t\t<h2 class=\"mbr-section-title mbr-bold mbr-fonts-style\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-title\">Building a Long-Term Partnership</h2>\n\t\t\t\t\t\t\t<p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\" mbr-if=\"showText\">Choosing the right patent attorney is about more than a single filing — it’s about establishing a long-term partnership that supports ongoing innovation. Specialized patent attorneys act as advisors who understand your business, industry trends, and future goals. This relationship allows for proactive protection strategies that evolve as your business grows.<br>\n<br>Project Patent by Kaufhold and Dix Patent Law emphasizes client-centric service, keeping inventors and companies informed at every step. Their combination of technical expertise, legal acumen, and transparent communication creates a supportive environment where innovators can focus on developing groundbreaking products and creative solutions.&nbsp;<br>\n\t\t\t\t\t\t\t</p>\n\t\t\t\t\t\t\t<div class=\"mbr-section-btn\" mbr-buttons mbr-theme-style=\"display-4\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\">\n\t\t\t\t\t\t\t\t<a class=\"btn btn-md btn-info\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">Sign In</a>\n\t\t\t\t\t\t\t</div>\n\t\t\t\t\t\t</div>\n\t\t\t\t\t</div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n</section>",
          "_isUserblock": true,
          "_cid": "v4vUJHwHUM",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "content10-s"
        },
        {
          "_name": "list03",
          "_sourceTheme": "sharpm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"list03 sharpm5\" group=\"List\" plugins=\"mbr-switch-arrow, mobirise-icons2\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"12\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"12\" step=\"1\" value=\"8\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\">\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\">\n        <header>List</header>\n        <select title=\"Amount\" name=\"cardAmount\">\n            <option value=\"1\">1</option>\n            <option value=\"2\">2</option>\n            <option value=\"3\">3</option>\n            <option value=\"4\">4</option>\n            <option value=\"5\" selected>5</option>\n            <option value=\"6\">6</option>\n        </select>\n        <header>Cards</header>\n        <input type=\"color\" title=\"Icon Color\" value=\"#000000\" name=\"iconColor\" selected>\n        <input type=\"color\" title=\"Icon BG\" value=\"#3a392d\" name=\"iconBg\" selected>\n        <input type=\"color\" title=\"Active Color\" value=\"#000000\" name=\"activeColor\" selected>\n        <input type=\"color\" title=\"Active BG\" value=\"#dbffea\" name=\"activeBg\" selected>\n        <input type=\"color\" title=\"Border Color\" value=\"#000000\" name=\"border\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@ADDONS_PATH@/sharpm5/components/_images/background1.jpg\">\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@ADDONS_PATH@/sharpm5/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\">\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#191919\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type !== 'color'\" opacity=\"{{overlayOpacity}}\" bg-color=\"{{overlayColor}}\"></div>\n\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row justify-content-center\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-5 card\">\n                <div class=\"title-wrapper\">\n                    <div class=\"title-wrap\" mbr-if=\"showTitle || showSubtitle\">\n                        <h2 class=\"mbr-section-title mbr-fonts-style\" data-app-selector=\".mbr-section-title\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\"><b>\n                            FAQ</b></h2>\n                        <h3 class=\"mbr-section-subtitle mbr-fonts-style\" data-app-selector=\".mbr-section-subtitle\" mbr-theme-style=\"display-2\" mbr-if=\"showSubtitle\">\n                            Business Strategies\n                        </h3>\n                    </div>\n                    <div class=\"text-wrapper\">\n                        <p class=\"mbr-text mbr-fonts-style\" mbr-if=\"showText\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-text, .text-wrapper\">\n                            Business Planner is your ultimate tool for structured business growth.\n                        </p>\n                    </div>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-5 card\">\n                <div class=\"items-wrapper\">\n                    <div id=\"bootstrap-accordion\" class=\"panel-group accordionStyles accordion\" role=\"tablist\" aria-multiselectable=\"true\">\n                        <div class=\"card little-radius\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingOne\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse1\" aria-expanded=\"false\" aria-controls=\"collapse1\">\n                                    <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">\n                                        What is Business Planner?\n                                    </h4>\n                                    <div class=\"icon-wrapper\">\n                                        <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                    </div>\n                                </a>\n                            </div>\n                            <div id=\"collapse1\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingOne\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-text\">\n                                        A patent attorney provides technical, legal, and strategic expertise that dramatically increases your chances of success. Self-filed applications are often rejected or too weak to defend effectively.\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card little-radius\" mbr-if=\"cardAmount > 1\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingTwo\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse2\" aria-expanded=\"false\" aria-controls=\"collapse2\">\n                                    <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">How long does it take to get a patent?</h4>\n                                    <div class=\"icon-wrapper\">\n                                        <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                    </div>\n                                </a>\n                            </div>\n                            <div id=\"collapse2\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingTwo\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-text\">\n                                        While timelines vary, most utility patents take between one and three years depending on complexity, examiner workload, and required amendments.\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card little-radius\" mbr-if=\"cardAmount > 2\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingThree\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse3\" aria-expanded=\"false\" aria-controls=\"collapse3\">\n                                    <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">Is a provisional patent enough to protect my idea?</h4>\n                                    <div class=\"icon-wrapper\">\n                                        <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                    </div>\n                                </a>\n                            </div>\n                            <div id=\"collapse3\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingThree\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-text\">\n                                        A provisional application only establishes an initial filing date; it does not provide enforceable rights. A full non-provisional application must follow within 12 months.\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card little-radius\" mbr-if=\"cardAmount > 3\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingFour\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse4\" aria-expanded=\"false\" aria-controls=\"collapse4\">\n                                    <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">Should I pursue trademarks or copyrights with my patent?</h4>\n                                    <div class=\"icon-wrapper\">\n                                        <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                    </div>\n                                </a>\n                            </div>\n                            <div id=\"collapse4\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFour\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-text\">\n                                        Often yes. Trademarks and copyrights protect branding and creative materials, adding layers of defense around your product and strengthening your market position.\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card little-radius\" mbr-if=\"cardAmount > 4\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingFive\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse5\" aria-expanded=\"false\" aria-controls=\"collapse5\">\n                                    <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">What makes a strong patent strategy?</h4>\n                                    <div class=\"icon-wrapper\">\n                                        <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                    </div>\n                                </a>\n                            </div>\n                            <div id=\"collapse5\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingFive\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-text\">\n                                        A strong strategy aligns your patent coverage with business goals, anticipates competitive threats, protects multiple aspects of your innovation, and evolves as your invention grows.\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                        <div class=\"card little-radius\" mbr-if=\"cardAmount > 5\">\n                            <div class=\"card-header\" role=\"tab\" id=\"headingSix\">\n                                <a role=\"button\" class=\"panel-title collapsed\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-core href=\"#collapse6\" aria-expanded=\"false\" aria-controls=\"collapse6\">\n                                    <h4 class=\"panel-title-edit mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-title-edit\">\n                                        How quickly can I start seeing results?\n                                    </h4>\n                                    <div class=\"icon-wrapper\">\n                                        <span class=\"sign mobi-mbri mobi-mbri-plus mbr-iconfont\"></span>\n                                    </div>\n                                </a>\n                            </div>\n                            <div id=\"collapse6\" class=\"panel-collapse noScroll collapse\" role=\"tabpanel\" aria-labelledby=\"headingSix\" data-parent=\"#accordion\" data-bs-parent=\"#accordion\">\n                                <div class=\"panel-body\">\n                                    <p class=\"panel-text mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".panel-text\">\n                                        While results vary, many users report improved clarity, efficiency, and\n                                        measurable growth within the first few months of using Business Planner.\n                                    </p>\n                                </div>\n                            </div>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            ".row": {
              "margin": "0 -15px",
              ".card": {
                "padding": "0 15px"
              }
            },
            ".title-wrapper": {
              "@media (max-width: 992px)": {
                "margin-bottom": "40px"
              },
              ".title-wrap": {
                "margin-bottom": "30px",
                ".mbr-section-title": {
                  "margin-bottom": "0"
                },
                ".mbr-section-subtitle": {
                  "margin-bottom": "0"
                }
              },
              ".text-wrapper": {
                ".mbr-text": {
                  "display": "inline-block",
                  "width": "60%",
                  "margin-bottom": "0",
                  "@media (max-width: 992px)": {
                    "width": "100%"
                  }
                }
              }
            },
            ".panel-group": {
              ".card": {
                "position": "relative",
                "padding": "0",
                "background-color": "transparent",
                "border": "1px solid @border",
                "transition": "all 0.3s ease-in-out",
                "margin-top": "15px",
                "&:first-child": {
                  "margin-top": "0"
                },
                ".card-header": {
                  "background-color": "transparent",
                  "border": "none",
                  "border-radius": "0",
                  "padding": "0",
                  ".panel-title": {
                    "display": "flex",
                    "justify-content": "space-between",
                    "align-items": "center",
                    "width": "100%",
                    "padding": "20px",
                    ".panel-title-edit": {
                      "margin-bottom": "0",
                      "transition": "all 0.3s ease-in-out"
                    },
                    ".icon-wrapper": {
                      "width": "24px",
                      "height": "24px",
                      "min-width": "24px",
                      "display": "inline-flex",
                      "align-items": "center",
                      "justify-content": "center",
                      "margin-left": "24px",
                      "transition": "all 0.3s ease-in-out",
                      "border-radius": "100%",
                      "background-color": "@iconBg",
                      ".mbr-iconfont": {
                        "font-size": "14px",
                        "transition": "all 0.3s ease-in-out",
                        "color": "@iconColor"
                      }
                    },
                    "&:not(.collapsed)": {
                      ".icon-wrapper": {
                        "transform": "rotate(-45deg)",
                        "background-color": "@activeBg",
                        ".mbr-iconfont": {
                          "color": "@activeColor"
                        }
                      }
                    }
                  }
                },
                ".panel-collapse": {
                  ".panel-body": {
                    "padding": "0 20px 20px 20px",
                    ".panel-text": {
                      "margin-bottom": "0"
                    }
                  }
                }
              }
            },
            ".mbr-section-title": {
              "color": "#000000"
            },
            ".mbr-section-subtitle": {
              "color": "#000000"
            },
            ".mbr-text": {
              "color": "#fefff5"
            },
            ".panel-title-edit": {
              "color": "#000000"
            },
            ".panel-text": {
              "color": "#000000"
            },
            ".mbr-text, .text-wrapper": {
              "color": "#000000"
            }
          },
          "_cid": "v4vWGS6pyY",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "list03-u"
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "overflow": "hidden",
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "padding": "0 60px",
                "@media (max-width: 992px)": {
                  "padding": "0 25px"
                }
              }
            },
            ".container": {
              "@media (max-width: 992px)": {
                "padding": "0 25px"
              }
            },
            ".row": {
              "justify-content": "center"
            },
            ".mbr-section-title": {
              "margin-bottom": "130px",
              "@media (max-width: 992px)": {
                "margin-bottom": "50px"
              },
              "color": "#ffffff"
            },
            ".list-wrapper": {
              "margin-bottom": "130px",
              "@media (max-width: 992px)": {
                "margin-bottom": "50px"
              },
              ".mbr-section-subtitle": {
                "margin-bottom": "20px"
              },
              ".list": {
                "margin": "0",
                "padding": "0",
                "list-style-type": "none",
                ".item-wrap": {
                  "margin-bottom": "16px",
                  "&:last-child": {
                    "margin-bottom": "0"
                  },
                  "&:hover, &:focus": {
                    "text-decoration": "underline"
                  }
                }
              }
            },
            ".content-wrapper": {
              "@media (max-width: 992px)": {
                "margin-bottom": "50px"
              },
              ".mbr-section-subtitle": {
                "margin-bottom": "20px"
              },
              ".mbr-text": {
                "margin-bottom": "20px"
              }
            },
            ".border-wrap": {
              "height": "2px",
              "background-color": "@border",
              "margin-bottom": "25px"
            },
            ".social-wrap": {
              "text-align": "right",
              "@media (max-width: 992px)": {
                "margin-top": "20px",
                "text-align": "center"
              },
              ".social-row": {
                "display": "inline-flex",
                "flex-wrap": "wrap",
                ".soc-item": {
                  "margin-right": "10px",
                  "a": {
                    "&:hover": {
                      ".mbr-iconfont": {
                        "background-color": "@activeBg",
                        "color": "@activeColor"
                      }
                    },
                    ".mbr-iconfont": {
                      "width": "30px",
                      "height": "30px",
                      "display": "inline-flex",
                      "align-items": "center",
                      "justify-content": "center",
                      "font-size": "16px",
                      "border-radius": "50%",
                      "transition": "all 0.4s ease-in-out",
                      "color": "@icon"
                    }
                  }
                }
              }
            },
            ".copyright": {
              "margin": "0",
              "@media (max-width: 992px)": {
                "margin-bottom": "20px"
              },
              "color": "#ffffff"
            },
            ".mbr-section-btn": {
              ".btn": {
                "margin-top": "0"
              },
              "text-align": "center"
            },
            ".mbr-section-subtitle": {
              "color": "#ffffff"
            },
            ".mbr-text": {
              "color": "#ffffff"
            },
            ".list": {
              "color": "#ffffff"
            }
          },
          "_name": "footer01",
          "_sourceTheme": "speakerm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"footer01\" group=\"Footer\" global once=\"footers\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Subtitle\" name=\"showSubtitle\" checked>\n        <input type=\"checkbox\" title=\"List 1\" name=\"showList_1\" checked>\n        <input type=\"checkbox\" title=\"List 2\" name=\"showList_2\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Secondary Buttons\" name=\"showSecButtons\" checked>\n        <input type=\"color\" title=\"Border Color\" value=\"#ffffff\" name=\"border\" selected>\n        <input type=\"checkbox\" title=\"Copyright\" name=\"showCopy\" checked>\n        <input type=\"checkbox\" title=\"Main Buttons\" name=\"showButtons\">\n        <input type=\"checkbox\" title=\"Social\" name=\"showSocial\">\n        <input type=\"range\" name=\"socialCount\" title=\"Count\" min=\"1\" max=\"3\" step=\"1\" value=\"3\" condition=\"showSocial\">\n        <input type=\"color\" title=\"Color\" name=\"icon\" value=\"#ffffff\" condition=\"showSocial\">\n        <input type=\"color\" title=\"Active BG\" name=\"activeBg\" value=\"#A0FFC2\" condition=\"showSocial\">\n        <input type=\"color\" title=\"Active Color\" name=\"activeColor\" value=\"#2f2e30\" condition=\"showSocial\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#000000\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#eff3f3\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.3\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-5\" mbr-if=\"showTitle\">\n                <h2 class=\"mbr-section-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".mbr-section-title\"><b><br></b><br><b><a href=\"https://projectpatent.com/\" class=\"text-white\">Project Patent by Kaufhold and Dix Patent Law</a></b></h2>\n            </div>\n            <div class=\"col-12 col-lg-2\" mbr-if=\"showList_2\">\n                <div class=\"list-wrapper\">\n                    <h4 class=\"mbr-section-subtitle mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-section-subtitle\" mbr-if=\"showSubtitle\"><b>Social Profile</b></h4>\n                    <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".list, .item-wrap\" data-multiline mbr-article>\n                        <li class=\"item-wrap\"><b><a href=\"https://www.linkedin.com/company/kaufhold-dix-patent-law\" class=\"text-white\">LinkedIn</a>\n</b></li><li class=\"item-wrap\"><b><a href=\"https://www.facebook.com/kaufholdlaw/\" class=\"text-white\">Facebook</a>\n</b></li><li class=\"item-wrap\"><b><a href=\"https://x.com/Kaufhold_Dix\" class=\"text-white\">Twitter</a>\n</b></li><li class=\"item-wrap\"><b><a href=\"https://www.instagram.com/kaufhold_dix/\" class=\"text-white\">Instagram</a>\n</b></li><li class=\"item-wrap\"><b><a href=\"https://www.youtube.com/channel/UCqrubqevEuwUTIYhiWQu7wQ\" class=\"text-white\">YouTube</a>\n</b></li><li class=\"item-wrap\"><b><a href=\"https://www.linkedin.com/in/sean-kaufhold-381ba010\" class=\"text-white\">LinkedIn</a>\n</b></li><li class=\"item-wrap\"><b><a href=\"https://featured.com/p/sean-kaufhold\" class=\"text-white\">Featured</a></b></li>\n                    </ul>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-2\" mbr-if=\"showList_1\">\n                <div class=\"list-wrapper\">\n                    <h4 class=\"mbr-section-subtitle mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-section-subtitle\" mbr-if=\"showSubtitle\"><b>Local Office</b></h4>\n                    <ul class=\"list mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".list, .item-wrap\" data-multiline mbr-article>\n                        <li class=\"item-wrap\"><a href=\"https://maps.app.goo.gl/QAoEsSXfuFz98AeW6\" class=\"text-white\">Sioux Falls, SD</a>\n</li><li class=\"item-wrap\"><a href=\"https://maps.app.goo.gl/FryrWgVqUQseBWjR9\" class=\"text-white\">Brookings, SD</a>\n</li><li class=\"item-wrap\"><a href=\"https://maps.app.goo.gl/3b91AK1cxVoUeaT87\" class=\"text-white\">Edina, MN</a>\n</li><li class=\"item-wrap\"><a href=\"https://maps.app.goo.gl/Ftm4C1RJTXV5syiF9\" class=\"text-white\">Maple Grove, MN</a>\n</li><li class=\"item-wrap\"><a href=\"https://maps.app.goo.gl/7kUKJ81yMYNYSNBJ6\" class=\"text-white\">White Oak, PA</a>\n</li><li class=\"item-wrap\"><a href=\"https://maps.app.goo.gl/A8KwVt1ZNx52qMy4A\" class=\"text-white\">Las Vegas, NV</a></li>\n                    </ul>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-3\">\n                <div class=\"content-wrapper\">\n                    <h4 class=\"mbr-section-subtitle mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-section-subtitle, .mbr-section-btn\" mbr-if=\"showSubtitle\"></h4>\n                    <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-text\" mbr-if=\"showText\"><a href=\"index.html\" class=\"text-white\"><br></a><br><a href=\"index.html\" class=\"text-white text-primary\">trademark law</a> </p>\n                    \n                </div>\n            </div>\n            <div class=\"col-12\">\n                <div class=\"border-wrap\"></div>\n            </div>\n            <div class=\"col-12 col-lg-4\" mbr-if=\"showCopy\">\n                <p class=\"copyright mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".copyright\">\n                    © Copyright 2025 - All Rights Reserved\n                </p>\n            </div>\n            <div class=\"col-12 col-lg-4\" mbr-if=\"showButtons\">\n                <div class=\"mbr-section-btn\" data-toolbar=\"-mbrBtnMove\" mbr-buttons mbr-theme-style=\"display-4\">\n                    <a href class=\"btn item-btn btn-secondary\" data-app-placeholder=\"Type Text\">\n                        Start Now\n                    </a>\n                </div>\n            </div>\n            <div class=\"col-12 col-lg-4\" mbr-if=\"showSocial\">\n                <div class=\"social-wrap\">\n                    <div class=\"social-row\">\n                        <div class=\"soc-item\">\n                            <a href=\"https://www.facebook.com/Mobirise/\" target=\"_blank\">\n                                <span mbr-icon class=\"mbr-iconfont socicon socicon-facebook\"></span>\n                            </a>\n                        </div>\n                        <div class=\"soc-item\" mbr-if=\"socialCount > 1\">\n                            <a href=\"https://twitter.com/mobirise\" target=\"_blank\">\n                                <span mbr-icon class=\"mbr-iconfont socicon socicon-twitter\"></span>\n                            </a>\n                        </div>\n                        <div class=\"soc-item\" mbr-if=\"socialCount > 2\">\n                            <a href=\"https://instagram.com/mobirise\" target=\"_blank\">\n                                <span mbr-icon class=\"mbr-iconfont socicon socicon-instagram\"></span>\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_cid": "v4vUJIzuY2",
          "_protectedParams": [],
          "_global": true,
          "_once": "footers",
          "_params": {},
          "_anchor": "footer01-t"
        }
      ]
