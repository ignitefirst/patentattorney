                "text-align": "center"
              },
              ".social-row": {
                "display": "inline-flex",
                "flex-wrap": "wrap",
                ".soc-item": {
                  "margin-right": "10px",
                  "a": {
                    "&:hover": {
                      ".mbr-iconfont": {
                        "background-color": "@activeBg",
                        "color": "@activeColor"
                      }
                    },
                    ".mbr-iconfont": {
                      "width": "30px",
