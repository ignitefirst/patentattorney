          "_name": "menu01",
          "_sourceTheme": "speakerm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"menu menu01 speakerm5\" group=\"Menu\" plugins=\"DropDown, TouchSwipe\" always-top global once=\"menu\" not-draggable position-absolute>\n\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" name=\"fullWidth\" title=\"Full Width\" checked>\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Logo\" name=\"showLogo\">\n        <input type=\"range\" title=\"Logo Size\" inline name=\"logoSize\" min=\"1\" max=\"8\" step=\"0.1\" value=\"3\" condition=\"showLogo\">\n        <input type=\"checkbox\" title=\"Brand Name\" name=\"showBrand\" checked>\n        <input type=\"checkbox\" title=\"Menu Items\" name=\"showItems\" condition=\"false\">\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\" checked>\n        <input type=\"checkbox\" title=\"Icons\" name=\"showIcons\">\n        <input type=\"range\" title=\"Amount\" name=\"iconsAmount\" min=\"0\" max=\"4\" step=\"1\" value=\"3\" condition=\"showIcons\">\n        <input type=\"color\" title=\"Color Icons\" name=\"iconsColor\" value=\"#2f2e30\" condition=\"showIcons\">\n        <header>Styles</header>\n        <input type=\"checkbox\" title=\"Sticky\" name=\"sticky\">\n        <input type=\"checkbox\" title=\"Collapsed\" name=\"collapsed\" condition=\"false\">\n        <input type=\"checkbox\" title=\"Transparent\" name=\"transparent\">\n        <input type=\"range\" title=\"Opacity\" name=\"opacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"1\" condition=\"transparent\">\n        <input type=\"color\" title=\"Color Menu\" name=\"menuBgColor\" value=\"#dbffea\">\n        <input type=\"color\" title=\"Hamburger\" name=\"hamburgerColor\" value=\"#2f2e30\">\n        <input type=\"color\" title=\"Hamburger Container\" name=\"hamburger\" value=\"#A0FFC2\">\n        <header>Sidebar</header>\n        <input type=\"checkbox\" title=\"Sidebar\" name=\"showSidebar\">\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" condition=\"showSidebar\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" condition=\"showSidebar\" checked>\n        <input type=\"checkbox\" title=\"Contacts\" name=\"showContacts\" condition=\"showSidebar\" checked>\n        <input type=\"color\" title=\"OffSidebar Color\" name=\"offSidebarColor\" value=\"#2f2e30\" condition=\"showSidebar\">\n    </mbr-parameters>\n\n    <nav class=\"navbar navbar-dropdown\" mbr-class=\"{'navbar-fixed-top':sticky,\n                     'navbar-expand-lg':!collapsed,\n                     'collapsed':collapsed}\">\n        <div class=\"menu_box\" mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n            <div class=\"navbar-brand d-flex\">\n                <span mbr-if=\"showLogo\" class=\"navbar-logo\">\n                    <a href=\"@THEME_PATH@/components/index.html\">\n                        <img src=\"@THEME_PATH@/components/_images/logo.png\" alt=\"Mobirise\" mbr-style=\"{'height': logoSize + 'rem'}\">\n                    </a>\n                </span>\n                <span mbr-if=\"showBrand\" mbr-buttons mbr-theme-style=\"display-5\" class=\"navbar-caption-wrap\" data-toolbar=\"-mbrBtnMove,-mbrBtnAdd,-mbrBtnRemove\"><a class=\"navbar-caption text-primary\" data-app-selector=\".navbar-caption\" href=\"index.html\" data-app-placeholder=\"Type Text\">Project Patent by Kaufhold and Dix Patent Law<br></a></span>\n                <button class=\"navbar-toggler\" type=\"button\" data-toggle=\"collapse\" data-bs-toggle=\"collapse\" data-target=\"#navbarSupportedContent\" data-bs-target=\"#navbarSupportedContent\" aria-controls=\"navbarNavAltMarkup\" aria-expanded=\"false\" aria-label=\"Toggle navigation\">\n                    <div class=\"hamburger\">\n                        <span></span>\n                        <span></span>\n                        <span></span>\n                        <span></span>\n                    </div>\n                </button>\n            </div>\n            <div class=\"collapse navbar-collapse\" id=\"navbarSupportedContent\">\n                <ul mbr-menu class=\"navbar-nav nav-dropdown\" mbr-theme-style=\"display-4\" mbr-class=\"{'nav-right': !showButtons,'navbar-nav-top-padding': isPublish && !showBrand && !showLogo}\"><li class=\"nav-item\"><a class=\"nav-link link text-black text-primary\" href=\"index.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Home</a></li>\n                    <li class=\"nav-item\"><a class=\"nav-link link text-black text-primary\" href=\"about-us.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">About Us</a></li>\n                    <li class=\"nav-item\"><a class=\"nav-link link text-black text-primary\" href=\"patent-attorney.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Patent Attorney</a></li>\n                    <li class=\"nav-item\"><a class=\"nav-link link text-black text-primary\" href=\"intellectual-property.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Intellectual Property<br></a></li><li class=\"nav-item\"><a class=\"nav-link link text-black text-primary\" href=\"patent-search.html\" data-app-selector=\".nav-link,.dropdown-item\" data-app-placeholder=\"Type Text\">Patent Search<br></a></li></ul>\n                <div class=\"icons-menu-main\" mbr-if=\"showIcons\">\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont socicon-facebook socicon\"></span>\n                    </a>\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 1\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont socicon-twitter socicon\"></span>\n                    </a>\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 2\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont socicon-instagram socicon\"></span>\n                    </a>\n                    <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 3\">\n                        <span mbr-icon class=\"p-2 mbr-iconfont socicon-linkedin socicon\"></span>\n                    </a>\n                </div>\n\n                <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn-main\" mbr-if=\"showButtons\" role=\"tablist\"><a class=\"btn btn-primary-outline\" href=\"index.html\" data-app-placeholder=\"Type Text\">\n                        Project Patent by Kaufhold and Dix Patent Law\n                    </a></div>\n            </div>\n            <div class=\"offcanvas_box\" mbr-if=\"showSidebar\">\n                <button class=\"btn_offcanvas\" type=\"button\" data-bs-toggle=\"offcanvas\" data-bs-target=\"#offcanvasRight\" aria-controls=\"offcanvasRight\">\n                    <div class=\"hamburger\">\n                        <span></span>\n                        <span></span>\n                    </div>\n                </button>\n                <div class=\"offcanvas offcanvas-end\" tabindex=\"-1\" id=\"offcanvasRight\" aria-labelledby=\"offcanvasRightLabel\">\n                    <div class=\"offcanvas-header\">\n                        <button type=\"button\" class=\"btn-close text-reset\" data-bs-dismiss=\"offcanvas\" aria-label=\"Close\"></button>\n                    </div>\n                    <div class=\"offcanvas-body\">\n                        <div mbr-if=\"showImage\" class=\"offcanvas_image\">\n                            <img src=\"@THEME_PATH@/components/_images/logo.png\" alt=\"Mobirise\" mbr-style=\"{'height': imageSize + 'rem'}\">\n                        </div>\n                        <h3 class=\"mbr-section-subtitle mbr-fonts-style\" mbr-if=\"showTitle\" data-app-selector=\".mbr-section-subtitle, .text_widget, .mbr-section-btn\" mbr-theme-style=\"display-2\">\n                            <b>SPEAKERM5</b>\n                        </h3>\n                        <div class=\"offcanvas_contact\">\n                            <p class=\"mbr-text mbr-fonts-style\" mbr-if=\"showText\" data-app-selector=\".mbr-text\" mbr-theme-style=\"display-7\">\n                                One of the key benefits of the business seminar is the opportunity for networking and\n                                collaboration. Participants interact with like-minded professionals from various\n                                industries, fostering meaningful connections and potential partnerships.\n                            </p>\n                            <p class=\"text_widget mbr-fonts-style\" mbr-if=\"showContacts\" data-app-selector=\".text_widget\" mbr-theme-style=\"display-4\">\n                                <a href=\"#\" class=\"text-white\">mobi@rise.com</a>\n                                <br><br>\n                                <a href=\"tel:12345678900\" class=\"text-white\">+1 234-567-8900</a>\n                            </p>\n                        </div>\n                        <div class=\"icons-menu\" mbr-if=\"showIcons\">\n                            <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\">\n                                <span mbr-icon class=\"p-2 mbr-iconfont socicon-youtube socicon\"></span>\n                            </a>\n                            <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 1\">\n                                <span mbr-icon class=\"p-2 mbr-iconfont socicon-twitter socicon\"></span>\n                            </a>\n                            <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 2\">\n                                <span mbr-icon class=\"p-2 mbr-iconfont socicon-instagram socicon\"></span>\n                            </a>\n                            <a class=\"iconfont-wrapper\" href=\"https://mobiri.se\" target=\"_blank\" mbr-if=\"iconsAmount > 3\">\n                                <span mbr-icon class=\"p-2 mbr-iconfont socicon-facebook socicon\"></span>\n                            </a>\n                        </div>\n                        <div mbr-buttons mbr-theme-style=\"display-4\" class=\"mbr-section-btn\" mbr-if=\"showButtons\">\n                            <a class=\"btn btn-white-outline\" href=\"https://mobiri.se\" data-app-placeholder=\"Type Text\">\n                                View More\n                            </a>\n                        </div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </nav>\n</section>",
          "_cid": "tKCS2rqgFe",
          "_anchor": "menu01-0",
          "_PHPplaceholders": [],
          "_JSplaceholders": [],
          "_protectedParams": [],
          "_global": true,
          "_once": "menu",
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "overflow": "hidden",
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "padding": "0 60px",
                "@media (max-width: 992px)": {
                  "padding": "0 25px"
                }
              }
            },
            ".container": {
              "@media (max-width: 992px)": {
                "padding": "0 25px"
              }
            },
            ".title-wrapper": {
              "padding": "60px 110px",
              "min-height": "500px",
              "display": "flex",
              "align-items": "center",
              "position": "relative",
              "margin-bottom": "30px",
              "@media (max-width: 1100px)": {
                "padding": "60px 25px"
              },
              "@media (max-width: 768px)": {
                "padding": "60px 10px"
              },
              "img": {
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                "height": "100%",
                "object-fit": "cover",
                "border-radius": "0 !important"
              },
              "&::after": {
                "content": "''",
                "position": "absolute",
                "top": "0",
                "left": "0",
                "width": "100%",
                "height": "100%",
                "background-color": "@primaryColor",
                "opacity": ".3",
                "pointer-events": "none"
              },
              ".title-wrap": {
                "position": "relative",
                "z-index": "1",
                "width": "100%",
                ".mbr-section-title": {
                  "margin-bottom": "16px"
                },
                ".mbr-text": {
                  "margin-bottom": "16px"
                }
              }
            },
            ".border-wrap": {
              "height": "2px",
              "background-color": "@border"
            },
            ".mbr-section-title": {
              "color": "#ffffff"
            },
            ".mbr-text": {
              "color": "#ffffff",
              "text-align": "center"
            },
            ".mbr-section-title, .mbr-section-btn": {
              "text-align": "center"
            }
          },
          "_name": "header01",
          "_sourceTheme": "speakerm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"header01\" group=\"Header\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <input type=\"checkbox\" title=\"Text\" name=\"showText\" checked>\n        <input type=\"checkbox\" title=\"Buttons\" name=\"showButtons\">\n        <input type=\"checkbox\" title=\"Border\" name=\"showBorder\" checked>\n        <input type=\"color\" title=\"Border Color\" value=\"#2f2e30\" name=\"border\" condition=\"showBorder\">\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n            <input type=\"video\" title=\"Video\" value=\"https://vimeo.com/428046504\">\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@THEME_PATH@/components/_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#eff3f3\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.1\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12\">\n                <div class=\"title-wrapper\">\n                    <img src=\"@PROJECT_PATH@/assets/images/0x0203-1200x900.jpg\" alt>\n                    <div class=\"title-wrap\">\n                        <h1 class=\"mbr-section-title mbr-fonts-style\" mbr-theme-style=\"display-1\" data-app-selector=\".mbr-section-title, .mbr-section-btn\" mbr-if=\"showTitle\"><b>How Copyright Law Protects Your Creative Works</b></h1>\n                        <p class=\"mbr-text mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\" mbr-if=\"showText\">\n                            Learn how copyright law protects your creative works and why creators rely on expert guidance from Project Patent by Kaufhold and Dix Patent Law. Discover how intellectual property, trademark law, and patent strategies work together to safeguard your ideas.\n                        </p>\n                        <div class=\"mbr-section-btn\" mbr-if=\"showButtons\" data-toolbar=\"-mbrBtnMove\" mbr-buttons mbr-theme-style=\"display-4\">\n                            <a href class=\"btn item-btn btn-white-outline\" data-app-placeholder=\"Type Text\">\n                                View More\n                            </a>\n                        </div>\n                    </div>\n                </div>\n                <div class=\"border-wrap\" mbr-if=\"showBorder\"></div>\n            </div>\n        </div>\n    </div>\n</section>",
          "_cid": "tKCS2BqYRX",
          "_anchor": "header01-1",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {}
        },
        {
          "alias": false,
          "_styles": {
            "& when not (@fullScreen)": {
              "padding-top": "(@paddingTop * 1rem)",
              "padding-bottom": "(@paddingBottom * 1rem)"
            },
            "overflow": "hidden",
            "& when (@bg-type = \"color\")": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = \"image\")": {
              "background-image": "url(@bg-value)"
            },
            ".mbr-fallback-image.disabled": {
              "display": "none"
            },
            ".mbr-fallback-image": {
              "display": "block",
              "background-size": "cover",
              "background-position": "center center",
              "width": "100%",
              "height": "100%",
              "position": "absolute",
              "top": "0",
              "& when (@bg-type = 'video')": {
                "background-image": "url(@fallBackImage)"
              }
            },
            "& when (@fullWidth)": {
              ".container-fluid": {
                "padding": "0 60px",
                "@media (max-width: 992px)": {
                  "padding": "0 25px"
                }
              }
            },
            ".container": {
              "@media (max-width: 992px)": {
                "padding": "0 25px"
              }
            },
            ".mbr-section-title": {
              "margin-bottom": "25px",
              "color": "#2f2e30"
            },
            ".item": {
              "margin-bottom": "50px",
              "padding-bottom": "10px",
              "border-bottom": "2px solid @border",
              ".item-wrapper": {
                "a": {
                  "display": "flex",
                  "align-items": "center",
                  "position": "relative",
                  "img": {
                    "position": "absolute",
                    "right": "0",
                    "width": "300px",
                    "height": "300px",
                    "border-radius": "0 !important",
                    "transform": "translateY(-10px) rotate(22deg)",
                    "transition": "all 0.3s ease-in-out",
                    "opacity": "0",
                    "object-fit": "cover",
                    "@media (max-width: 992px)": {
                      "display": "none"
                    }
                  },
                  "&:hover, &:focus": {
                    "img": {
                      "transform": "translateY(0) rotate(22deg)",
                      "opacity": "1"
                    }
                  },
                  ".card-box": {
                    "position": "relative",
                    "display": "flex",
                    "align-items": "center",
                    "@media (max-width: 992px)": {
                      "display": "block"
                    },
                    ".number-wrap": {
                      "display": "flex",
                      "align-items": "center",
                      "margin-right": "56px",
                      "@media (max-width: 992px)": {
                        "margin": "0 0 10px 0"
                      },
                      ".mbr-number": {
                        "display": "flex",
                        "align-items": "center",
                        "justify-content": "center",
                        "width": "72px",
                        "height": "72px",
                        "min-width": "72px",
                        "border-radius": "50%",
                        "background-color": "@number",
                        "margin-right": "10px",
                        "margin-bottom": "0"
                      },
                      ".mbr-desc": {
                        "margin-bottom": "0",
                        "min-width": "37px"
                      }
                    },
                    ".mbr-card-title": {
                      "margin": "0"
                    }
                  }
                }
              }
            },
            ".mbr-number": {
              "color": "#2f2e30"
            },
            ".mbr-card-title": {
              "color": "#000000"
            },
            ".mbr-desc": {
              "color": "#2f2e30"
            }
          },
          "_name": "list01",
          "_sourceTheme": "speakerm5",
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"list01\" group=\"List\" mbr-class=\"{\n    'mbr-fullscreen': fullScreen,\n    'mbr-parallax-background': bg.parallax}\">\n    <mbr-parameters>\n        <header>Size</header>\n        <input type=\"checkbox\" title=\"Full Screen\" name=\"fullScreen\">\n        <input type=\"checkbox\" title=\"Full Width\" name=\"fullWidth\" checked>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"5\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"0\">\n        <input type=\"checkbox\" title=\"Reverse\" name=\"reverseContent\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Title\" name=\"showTitle\" checked>\n        <header>Cards</header>\n        <input type=\"checkbox\" title=\"Number\" name=\"showNumber\">\n        <input type=\"color\" title=\"Number BG\" value=\"#A0FFC2\" name=\"number\" condition=\"showNumber\" selected>\n        <input type=\"checkbox\" title=\"Card Description\" name=\"showDesc\">\n        <input type=\"checkbox\" title=\"Card Title\" name=\"showCardTitle\" checked>\n        <input type=\"color\" title=\"Border Color\" value=\"#2f2e30\" name=\"border\" selected>\n        <header>Background</header>\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Image\" value=\"../_images/background1.jpg\" parallax>\n            <input type=\"color\" title=\"Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"../_images/background1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#eff3f3\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.3\" condition=\"overlay && bg.type !== 'color'\">\n    </mbr-parameters>\n\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\"></div>\n    <div mbr-class=\"{'container': !fullWidth, 'container-fluid': fullWidth}\">\n        <div class=\"row\" mbr-class=\"{'flex-row-reverse' : reverseContent}\">\n            <div class=\"col-12 col-lg-4\">\n                <h2 class=\"mbr-section-title mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".mbr-section-title\" mbr-if=\"showTitle\"><b><br></b><br><br><b>Project Patent by Kaufhold and Dix Patent Law</b></h2>\n            </div>\n            <div class=\"col-12 col-lg-8\">\n                <div class=\"item features-without-image item-mb\">\n                    <div class=\"item-wrapper\">\n                        <a href=\"#\">\n                            \n                            <div class=\"card-box\">\n                                <div class=\"number-wrap\" mbr-if=\"showNumber || showDesc\">\n                                    <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".mbr-number\" mbr-if=\"showNumber\">\n                                        <b>05</b>\n                                    </p>\n                                    <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-desc\" mbr-if=\"showDesc\">\n                                        Apr <br> Fri\n                                    </p>\n                                </div>\n                                <h4 class=\"mbr-card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-card-title\" mbr-if=\"showCardTitle\"><b><a href=\"index.html#header2-3\" class=\"text-black\">Protecting Innovations with Project Patent by Kaufhold and Dix Patent Law</a></b></h4>\n                            </div>\n                        </a>\n                    </div>\n                </div>\n                <div class=\"item features-without-image item-mb\">\n                    <div class=\"item-wrapper\">\n                        <a href=\"#\">\n                            \n                            <div class=\"card-box\">\n                                <div class=\"number-wrap\" mbr-if=\"showNumber || showDesc\">\n                                    <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".mbr-number\" mbr-if=\"showNumber\">\n                                        <b>10</b>\n                                    </p>\n                                    <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-desc\" mbr-if=\"showDesc\">\n                                        Apr <br> Tue\n                                    </p>\n                                </div>\n                                <h4 class=\"mbr-card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-card-title\" mbr-if=\"showCardTitle\"><b><a href=\"index.html#aarticle2-4\" class=\"text-black\">Why Copyright Matters in the Digital Age</a></b></h4>\n                            </div>\n                        </a>\n                    </div>\n                </div>\n                <div class=\"item features-without-image item-mb\">\n                    <div class=\"item-wrapper\">\n                        <a href=\"#\">\n                            \n                            <div class=\"card-box\">\n                                <div class=\"number-wrap\" mbr-if=\"showNumber || showDesc\">\n                                    <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".mbr-number\" mbr-if=\"showNumber\">\n                                        <b>12</b>\n                                    </p>\n                                    <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-desc\" mbr-if=\"showDesc\">\n                                        Apr <br> Thu\n                                    </p>\n                                </div>\n                                <h4 class=\"mbr-card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-card-title\" mbr-if=\"showCardTitle\"><b><a href=\"index.html#article04-0\" class=\"text-black\">How Copyright Interacts with Other Types of Intellectual Property</a></b></h4>\n                            </div>\n                        </a>\n                    </div>\n                </div>\n                <div class=\"item features-without-image item-mb\">\n                    <div class=\"item-wrapper\">\n                        \n                           \n                            <div class=\"card-box\">\n                                <div class=\"number-wrap\" mbr-if=\"showNumber || showDesc\">\n                                    <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".mbr-number\" mbr-if=\"showNumber\">\n                                        <b>19</b>\n                                    </p>\n                                    <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-desc\" mbr-if=\"showDesc\">\n                                        Apr <br> Thu\n                                    </p>\n                                </div>\n                                <h4 class=\"mbr-card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-card-title\" mbr-if=\"showCardTitle\"><b><a href=\"index.html#aarticle2-5\" class=\"text-black\">When Registration Becomes Essential</a></b></h4>\n                            </div>\n                        \n                    </div>\n                </div><div class=\"item features-without-image item-mb\">\n                    <div class=\"item-wrapper\">\n                        \n                           \n                            <div class=\"card-box\">\n                                <div class=\"number-wrap\" mbr-if=\"showNumber || showDesc\">\n                                    <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".mbr-number\" mbr-if=\"showNumber\">\n                                        <b>19</b>\n                                    </p>\n                                    <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-desc\" mbr-if=\"showDesc\">\n                                        Apr <br> Thu\n                                    </p>\n                                </div>\n                                <h4 class=\"mbr-card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-card-title\" mbr-if=\"showCardTitle\"><b><a href=\"index.html#content2-6\" class=\"text-black\">How Professional Guidance Strengthens Creative Protection</a></b></h4>\n                            </div>\n                        \n                    </div>\n                </div><div class=\"item features-without-image item-mb\">\n                    <div class=\"item-wrapper\">\n                        <a href=\"#\">\n                           \n                            <div class=\"card-box\">\n                                <div class=\"number-wrap\" mbr-if=\"showNumber || showDesc\">\n                                    <p class=\"mbr-number mbr-fonts-style\" mbr-theme-style=\"display-5\" data-app-selector=\".mbr-number\" mbr-if=\"showNumber\">\n                                        <b>19</b>\n                                    </p>\n                                    <p class=\"mbr-desc mbr-fonts-style\" mbr-theme-style=\"display-4\" data-app-selector=\".mbr-desc\" mbr-if=\"showDesc\">\n                                        Apr <br> Thu\n                                    </p>\n                                </div>\n                                <h4 class=\"mbr-card-title mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-card-title\" mbr-if=\"showCardTitle\"><b><a href=\"index.html#content10-7\" class=\"text-black\">Building a Future Where Creativity Thrives</a></b></h4>\n                            </div>\n                        </a>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</section>",
