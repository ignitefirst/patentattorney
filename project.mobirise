              },
              ".mbr-text": {
                "margin-bottom": "20px"
              }
            },
            ".border-wrap": {
              "height": "2px",
              "background-color": "@border",
              "margin-bottom": "25px"
            },
            ".social-wrap": {
              "text-align": "right",
              "@media (max-width: 992px)": {
