          },
          "_customHTML": "<section data-bs-version=\"5.1\" class=\"content2\" group=\"Content\" data-bg-video=\"{{bg.type == 'video' && bg.value.url}}\" mbr-class=\"{'mbr-parallax-background': bg.parallax}\">\n\n    <mbr-parameters>\n        \n        <header>Size</header>\n        <input type=\"range\" inline title=\"Top\" name=\"paddingTop\" min=\"0\" max=\"10\" step=\"1\" value=\"4\">\n        <input type=\"range\" inline title=\"Bottom\" name=\"paddingBottom\" min=\"0\" max=\"10\" step=\"1\" value=\"4\">\n        <header>Show/Hide</header>\n        <input type=\"checkbox\" title=\"Show Button\" name=\"showButtons\">\n        <input type=\"checkbox\" title=\"Media On Right/Left\" name=\"mediaLeft\">\n        <input type=\"checkbox\" title=\"Show Title\" name=\"showTitle\" checked> \n        <header>Background</header>\n        <input type=\"color\" title=\"Card Background\" value=\"#dbffea\" name=\"cardColor\">\n        <fieldset type=\"background\" name=\"bg\" parallax>\n            <input type=\"image\" title=\"Background Image\" value=\"@PROJECT_PATH@/assets/images/bg-3.jpg\">\n            <input type=\"video\" title=\"Background Video\" value=\"https://vimeo.com/171547423\">\n            <input type=\"color\" title=\"Background Color\" value=\"#ffffff\" selected>\n        </fieldset>\n        <header condition=\"bg.type === 'video'\">Fallback Image</header>\n        <input type=\"image\" title=\"Fallback Image\" value=\"@PROJECT_PATH@/assets/images/bg-1.jpg\" name=\"fallBackImage\" condition=\"bg.type === 'video'\">\n\n        <input type=\"checkbox\" title=\"Overlay\" name=\"overlay\" condition=\"bg.type !== 'color'\" checked>\n        <input type=\"color\" title=\"Overlay Color\" name=\"overlayColor\" value=\"#ffffff\" condition=\"overlay && bg.type !== 'color'\">\n        <input type=\"range\" inline title=\"Opacity\" name=\"overlayOpacity\" min=\"0\" max=\"1\" step=\"0.1\" value=\"0.8\" condition=\"overlay && bg.type !== 'color'\">\n        \n    </mbr-parameters>\n    <div class=\"mbr-fallback-image disabled\" mbr-if=\"bg.type == 'video'\"></div>\n\n\n    <div class=\"mbr-overlay\" mbr-if=\"overlay && bg.type!== 'color'\" mbr-style=\"{'opacity': overlayOpacity, 'background-color': overlayColor}\">\n    </div>\n\n    <div class=\"container\">\n        <div class=\"row content-row align-items-center\">\n            <div class=\"col-md-12\" mbr-class=\"{'col-lg-8' : showButtons, 'col-lg-12' : !showButtons}\">\n                <h1 class=\"mbr-section-title mbr-fonts-style mb-3 mbr-bold\" mbr-theme-style=\"display-2\" mbr-if=\"showTitle\">Benefits of a Full-Service Patent Service</h1>\n                <p class=\"mbr-text mbr-black mbr-regular mbr-light mbr-fonts-style\" mbr-theme-style=\"display-7\" data-app-selector=\".mbr-text\">Engaging a full-service patent service offers more than just filing applications. Experts at Project Patent support clients from the initial idea assessment to follow-up during <a href=\"https://projectpatent.com/faq\" class=\"text-primary\"><b><u>patent examination</u></b></a>. This transparent, flat-fee model ensures inventors know what to expect financially while receiving professional guidance at every stage. From understanding potential prior art to crafting enforceable claims and responding to patent office actions, a full-service firm ensures no aspect of the process is overlooked. This end-to-end support is especially valuable for individual inventors and small businesses looking to protect their innovations without unexpected legal hurdles.<br></p>\n            </div>\n            <div class=\"col-md-12 col-lg-4\" mbr-if=\"showButtons\">\n                <div class=\"mbr-section-btn align-right\" mbr-buttons data-toolbar=\"-mbrBtnMove,-mbrBtnRemove,-mbrBtnAdd\" mbr-theme-style=\"display-4\"><a class=\"btn btn-info btn-md\" href=\"#\" data-app-placeholder=\"Type Text\">Get in touch!</a></div>\n            </div>\n\n        </div>\n    </div>\n</section>",
          "_isUserblock": true,
          "_cid": "v4vZIgRhBW",
          "_protectedParams": [],
          "_global": false,
          "_once": false,
          "_params": {},
          "_anchor": "content2-1f"
        },
        {
          "_name": "content10",
          "_sourceTheme": "marketm4",
          "_styles": {
            "padding-top": "(@paddingTop * 1rem)",
            "padding-bottom": "(@paddingBottom * 1rem)",
            "& when (@bg-type = 'color')": {
              "background-color": "@bg-value"
            },
            "& when (@bg-type = 'image')": {
              "background-image": "url(@bg-value)"
            },
            ".block__inner": {
              "padding": "65px 20px 75px",
              "border-radius": "10px",
              "border": "2px solid @borderColor"
            },
            ".mbr-iconfont": {
              "font-size": "62px",
              "color": "@iconColor"
            },
            ".mbr-section-title": {
              "margin-top": "25px",
              "margin-bottom": "0",
              "color": "#000000"
            },
            ".mbr-text": {
              "margin-top": "25px",
              "margin-bottom": "0",
              "color": "#000000"
